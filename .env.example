# Environment variables for the serverless functions (api/ask.js, api/medium.js).
# Copy to `.env` for local `vercel dev`, and set the same keys in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
#
# The API key is used ONLY server-side inside the functions. It is never sent to the
# browser and must never be committed. Do not put it in index.html or main.js.

# Required: your Anthropic API key (Sri uses claude-haiku-4-5).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: lock CORS to your site's origin instead of "*".
# ALLOWED_ORIGIN=https://srikanthreddynandireddy.me

# Optional: override the Medium feed the proxy fetches.
# MEDIUM_FEED_URL=https://medium.com/feed/@srikanth2314
